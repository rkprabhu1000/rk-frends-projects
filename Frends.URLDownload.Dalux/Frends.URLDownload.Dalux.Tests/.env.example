# Rename this file to .env to run the live integration test locally.
# The unit tests run without any external dependencies.

DALUX_EMAIL=your.email@example.com
DALUX_PASSWORD=YourDaluxPassword

# Full login URL including the returnUrl that redirects to the file after login
DALUX_CALLING_URL=https://node1.build.dalux.com/client/login?returnUrl=...

# Direct file download URL
DALUX_FILE_URL=https://node1.field.dalux.com/service/web/downloadfile/project-xxx/areafilerevision-yyy
